{
  "manifest_version": 3,
  "name": "Sales Copilot",
  "version": "2.1",
  "description": "AI-powered sales assistant — analyze any web page for outreach insights",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
